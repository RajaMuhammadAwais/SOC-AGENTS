APP_ENV=local
APP_NAME=Enterprise AI SOC
API_HOST=0.0.0.0
API_PORT=8000

DATABASE_URL=postgresql+asyncpg://soc:soc@localhost:5432/soc
REDIS_URL=redis://localhost:6379/0

JWT_ISSUER=enterprise-ai-soc
JWT_AUDIENCE=enterprise-ai-soc-api
JWT_SECRET_KEY=replace-with-a-secret-manager-value
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

PINECONE_API_KEY=
PINECONE_INDEX=soc-knowledge
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
EMBEDDING_DIMENSION=1024
EMBEDDING_PROVIDER=bge-m3
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_BATCH_SIZE=12
EMBEDDING_MAX_LENGTH=8192
BGE_M3_USE_FP16=true
HF_TOKEN=
RERANKER_PROVIDER=bge-reranker-v2-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_BATCH_SIZE=12
RERANKER_MAX_LENGTH=8192
BGE_RERANKER_USE_FP16=true

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_FALLBACK_MODELS=nvidia/nemotron-3-nano-30b-a3b:free
OPENROUTER_TIMEOUT_SECONDS=60
OPENROUTER_REFERER=http://localhost
LLM_PROVIDER=openrouter
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free
LANGSMITH_TRACING=false
